      <title>エラズマス・ダーウィン</title>
      <link>http://localhost:1313/40_academic/48_person/%E3%82%A8%E3%83%A9%E3%82%BA%E3%83%9E%E3%82%B9%E3%83%80%E3%83%BC%E3%82%A6%E3%82%A3%E3%83%B3/</link>
