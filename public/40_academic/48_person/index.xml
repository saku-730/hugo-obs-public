      <guid>http://localhost:1313/40_academic/48_person/%E3%82%A8%E3%83%A9%E3%82%BA%E3%83%9E%E3%82%B9%E3%83%80%E3%83%BC%E3%82%A6%E3%82%A3%E3%83%B3/</guid>
      <description>&lt;h6 id=&#34;目次&#34;&gt;&lt;strong&gt;目次&lt;/strong&gt;&lt;/h6&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;&#34;&gt;&lt;code class=&#34;language-toc&#34; data-lang=&#34;toc&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;style:nestedList&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;minLevel:2&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;maxLevel:5&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h1 id=&#34;エラズマスダーウィン&#34;&gt;エラズマス・ダーウィン&lt;/h1&gt;&#xA;&lt;h2 id=&#34;基本情報&#34;&gt;基本情報&lt;/h2&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;本名：&lt;/li&gt;&#xA;&lt;li&gt;出身：&lt;/li&gt;&#xA;&lt;li&gt;年-年&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;h2 id=&#34;進化&#34;&gt;進化&lt;/h2&gt;&#xA;&lt;p&gt;個々の「種」や世界全体について完璧な状態を目指してより複雑な性質のものへと発達していくものだと信じていた。種の変化を受けて入れていた。&lt;/p&gt;&#xA;&lt;h2 id=&#34;年表&#34;&gt;年表&lt;/h2&gt;&#xA;&lt;h2 id=&#34;著作&#34;&gt;著作&lt;/h2&gt;&#xA;&lt;h2 id=&#34;関連&#34;&gt;関連&lt;/h2&gt;&#xA;&lt;h2 id=&#34;参考&#34;&gt;参考&lt;/h2&gt;&#xA;&lt;ol&gt;&#xA;&lt;li&gt;&lt;a href=&#34;http://localhost:1313/30_reading_record/32_science/%E8%A5%BF%E6%B4%8B%E5%8D%9A%E7%89%A9%E5%AD%A6%E8%80%85%E5%88%97%E4%BC%9D/&#34;&gt;西洋博物学者列伝&lt;/a&gt;p159-164&lt;/li&gt;&#xA;&lt;/ol&gt;</description>
    </item>
    <item>
      <title>カール・リンネ</title>
      <link>http://localhost:1313/40_academic/48_person/%E3%82%AB%E3%83%BC%E3%83%AB%E3%83%AA%E3%83%B3%E3%83%8D/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/40_academic/48_person/%E3%82%AB%E3%83%BC%E3%83%AB%E3%83%AA%E3%83%B3%E3%83%8D/</guid>
      <description>&lt;h6 id=&#34;目次&#34;&gt;&lt;strong&gt;目次&lt;/strong&gt;&lt;/h6&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;&#34;&gt;&lt;code class=&#34;language-toc&#34; data-lang=&#34;toc&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;style:nestedList&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;minLevel:2&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;maxLevel:5&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h1 id=&#34;カールリンネ&#34;&gt;カール・リンネ&lt;/h1&gt;&#xA;&lt;h2 id=&#34;基本情報&#34;&gt;基本情報&lt;/h2&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;本名：Carl von Linné&lt;/li&gt;&#xA;&lt;li&gt;出身：スウェーデン&lt;/li&gt;&#xA;&lt;li&gt;1707年-1778年&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;h2 id=&#34;分類の基礎&#34;&gt;分類の基礎&lt;/h2&gt;&#xA;&lt;p&gt;1735年の『自然の体系』にはじまり次々に分類について発表する。ただしこの『自然の体系』は猛烈な反発にあう。主な反発は神学的な命名をひどく貶めるといった内容。&lt;/p&gt;&#xA;&lt;p&gt;植物は神によって正しい関係になるよう配置されたのだから自然な分類法が神の創造行為から導き出されると信じていた。&lt;/p&gt;&#xA;&lt;p&gt;分類階層については5段階、界・綱・目・属・種 を作った。&lt;/p&gt;&#xA;&lt;h2 id=&#34;二名法&#34;&gt;二名法&lt;/h2&gt;&#xA;&lt;p&gt;1753年『植物の種』で提示された命名法。書名の通り最初は植物を対象としていた。二名法以前は酒について説明的に言葉を並べる多名法であったが長く冗長であった。これを解消しかつ基本的なラテン語だけで区別でき応用しやすい。&lt;/p&gt;&#xA;&lt;p&gt;スイスの植物学者・解剖学者のガスポール・ボーアンが1623年に『植物の劇場総覧』にてすでに二名法を提案していた。&lt;/p&gt;&#xA;&lt;h2 id=&#34;年表&#34;&gt;年表&lt;/h2&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;1735:「自然の体系」の出版&lt;/li&gt;&#xA;&lt;li&gt;&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;h2 id=&#34;著作&#34;&gt;著作&lt;/h2&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;自然の体系&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;h2 id=&#34;関連&#34;&gt;関連&lt;/h2&gt;&#xA;&lt;h3 id=&#34;人&#34;&gt;人&lt;/h3&gt;&#xA;&lt;h2 id=&#34;参考&#34;&gt;参考&lt;/h2&gt;&#xA;&lt;ol&gt;&#xA;&lt;li&gt;&lt;a href=&#34;http://localhost:1313/30_reading_record/32_science/%E8%A5%BF%E6%B4%8B%E5%8D%9A%E7%89%A9%E5%AD%A6%E8%80%85%E5%88%97%E4%BC%9D/&#34;&gt;西洋博物学者列伝&lt;/a&gt;p133-139&lt;/li&gt;&#xA;&lt;/ol&gt;</description>
    </item>
    <item>
      <title>ジャン-バティスト・ラマルク</title>
      <link>http://localhost:1313/40_academic/48_person/%E3%82%B8%E3%83%A3%E3%83%B3-%E3%83%90%E3%83%86%E3%82%A3%E3%82%B9%E3%83%88%E3%83%A9%E3%83%9E%E3%83%AB%E3%82%AF/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/40_academic/48_person/%E3%82%B8%E3%83%A3%E3%83%B3-%E3%83%90%E3%83%86%E3%82%A3%E3%82%B9%E3%83%88%E3%83%A9%E3%83%9E%E3%83%AB%E3%82%AF/</guid>
      <description>&lt;h6 id=&#34;目次&#34;&gt;&lt;strong&gt;目次&lt;/strong&gt;&lt;/h6&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;&#34;&gt;&lt;code class=&#34;language-toc&#34; data-lang=&#34;toc&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;style:nestedList&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;minLevel:2&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;maxLevel:5&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h1 id=&#34;ジャン-バティストラマルク&#34;&gt;ジャン-バティスト・ラマルク&lt;/h1&gt;&#xA;&lt;h2 id=&#34;基本情報&#34;&gt;基本情報&lt;/h2&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;本名：&lt;/li&gt;&#xA;&lt;li&gt;出身：&lt;/li&gt;&#xA;&lt;li&gt;年-年&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;h2 id=&#34;進化&#34;&gt;進化&lt;/h2&gt;&#xA;&lt;p&gt;無脊椎動物の研究の中で生物の相互のつながり、「相同」を発見していた。生命体が単純なものから複雑なものへと連なると考えた。これを示すため樹形図を作成しこれは系統図の基礎となる。&lt;/p&gt;&#xA;&lt;h2 id=&#34;年表&#34;&gt;年表&lt;/h2&gt;&#xA;&lt;h2 id=&#34;著作&#34;&gt;著作&lt;/h2&gt;&#xA;&lt;h2 id=&#34;関連&#34;&gt;関連&lt;/h2&gt;&#xA;&lt;h2 id=&#34;参考&#34;&gt;参考&lt;/h2&gt;&#xA;&lt;ol&gt;&#xA;&lt;li&gt;&lt;a href=&#34;http://localhost:1313/30_reading_record/32_science/%E8%A5%BF%E6%B4%8B%E5%8D%9A%E7%89%A9%E5%AD%A6%E8%80%85%E5%88%97%E4%BC%9D/&#34;&gt;西洋博物学者列伝&lt;/a&gt;&lt;/li&gt;&#xA;&lt;/ol&gt;</description>
    </item>
