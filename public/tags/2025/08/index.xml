      <link>http://localhost:1313/40_academic/48_person/%E3%82%B8%E3%83%A3%E3%83%B3-%E3%83%90%E3%83%86%E3%82%A3%E3%82%B9%E3%83%88%E3%83%A9%E3%83%9E%E3%83%AB%E3%82%AF/</link>
