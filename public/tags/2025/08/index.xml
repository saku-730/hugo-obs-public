      <guid>http://localhost:1313/40_academic/48_person/%E3%82%B8%E3%83%A3%E3%83%B3-%E3%83%90%E3%83%86%E3%82%A3%E3%82%B9%E3%83%88%E3%83%A9%E3%83%9E%E3%83%AB%E3%82%AF/</guid>
      <description>&lt;h6 id=&#34;目次&#34;&gt;&lt;strong&gt;目次&lt;/strong&gt;&lt;/h6&gt;&#xA;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; style=&#34;color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;&#34;&gt;&lt;code class=&#34;language-toc&#34; data-lang=&#34;toc&#34;&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;style:nestedList&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;minLevel:2&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;maxLevel:5&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h1 id=&#34;ジャン-バティストラマルク&#34;&gt;ジャン-バティスト・ラマルク&lt;/h1&gt;&#xA;&lt;h2 id=&#34;基本情報&#34;&gt;基本情報&lt;/h2&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;本名：&lt;/li&gt;&#xA;&lt;li&gt;出身：&lt;/li&gt;&#xA;&lt;li&gt;年-年&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;h2 id=&#34;進化&#34;&gt;進化&lt;/h2&gt;&#xA;&lt;p&gt;無脊椎動物の研究の中で生物の相互のつながり、「相同」を発見していた。生命体が単純なものから複雑なものへと連なると考えた。これを示すため樹形図を作成しこれは系統図の基礎となる。&lt;/p&gt;&#xA;&lt;h2 id=&#34;年表&#34;&gt;年表&lt;/h2&gt;&#xA;&lt;h2 id=&#34;著作&#34;&gt;著作&lt;/h2&gt;&#xA;&lt;h2 id=&#34;関連&#34;&gt;関連&lt;/h2&gt;&#xA;&lt;h2 id=&#34;参考&#34;&gt;参考&lt;/h2&gt;&#xA;&lt;ol&gt;&#xA;&lt;li&gt;&lt;a href=&#34;http://localhost:1313/30_reading_record/32_science/%E8%A5%BF%E6%B4%8B%E5%8D%9A%E7%89%A9%E5%AD%A6%E8%80%85%E5%88%97%E4%BC%9D/&#34;&gt;西洋博物学者列伝&lt;/a&gt;&lt;/li&gt;&#xA;&lt;/ol&gt;</description>
