    <item>
      <title>眠れぬ夜に読む本</title>
      <link>http://localhost:1313/30_reading_record/36_novel/%E7%9C%A0%E3%82%8C%E3%81%AC%E5%A4%9C%E3%81%AB%E8%AA%AD%E3%82%80%E6%9C%AC/</link>
