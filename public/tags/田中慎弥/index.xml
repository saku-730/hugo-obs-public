    <item>
      <title>孤独に生きよ</title>
      <link>http://localhost:1313/30_reading_record/35_humanities/%E5%AD%A4%E7%8B%AC%E3%81%AB%E7%94%9F%E3%81%8D%E3%82%88/</link>
