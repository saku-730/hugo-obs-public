    <item>
      <title>西洋博物学者列伝</title>
      <link>http://localhost:1313/30_reading_record/32_science/%E8%A5%BF%E6%B4%8B%E5%8D%9A%E7%89%A9%E5%AD%A6%E8%80%85%E5%88%97%E4%BC%9D/</link>
