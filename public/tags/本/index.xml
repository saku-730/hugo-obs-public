      <link>http://localhost:1313/30_reading_record/31_living_things/%E3%83%89%E3%83%BC%E3%82%AD%E3%83%B3%E3%82%B9vs%E3%82%B0%E3%83%BC%E3%83%AB%E3%83%89/</link>
