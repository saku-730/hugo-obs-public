    </item>
    <item>
      <title>つねならぬ話</title>
      <link>http://localhost:1313/30_reading_record/36_novel/%E3%81%A4%E3%81%AD%E3%81%AA%E3%82%89%E3%81%AC%E8%A9%B1/</link>
